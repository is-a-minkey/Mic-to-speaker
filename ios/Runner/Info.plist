<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist — Megaphone
  Place this file at:  ios/Runner/Info.plist
  (merge with or replace the Flutter-generated default)
-->
<plist version="1.0">
<dict>

    <!-- ═══════════════════════════════════════════════════
         APP IDENTITY
         ═══════════════════════════════════════════════════ -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>

    <key>CFBundleDisplayName</key>
    <string>Megaphone</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>megaphone</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <!-- ═══════════════════════════════════════════════════
         REQUIRED PERMISSIONS
         ═══════════════════════════════════════════════════ -->

    <!--
      NSMicrophoneUsageDescription
      iOS will show this string in the system permission dialog.
      Be specific — App Store reviewers read this.
    -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Megaphone needs your microphone to capture your voice and route it in real time to the speaker — the app's core function.</string>

    <!-- ═══════════════════════════════════════════════════
         BACKGROUND AUDIO (keeps transmission alive when
         the screen is locked or the app is backgrounded)
         ═══════════════════════════════════════════════════ -->
    <key>UIBackgroundModes</key>
    <array>
        <!-- Audio playback / recording in background -->
        <string>audio</string>
        <!-- VoIP processing — allows low-latency audio when backgrounded -->
        <string>voip</string>
    </array>

    <!-- ═══════════════════════════════════════════════════
         AUDIO SESSION CONFIGURATION
         flutter_sound respects these keys for AEC & routing
         ═══════════════════════════════════════════════════ -->

    <!--
      The AVAudioSession category is set programmatically by flutter_sound
      to PlayAndRecord with .defaultToSpeaker and .allowBluetooth options.
      No additional plist keys are required for that.
    -->

    <!-- ═══════════════════════════════════════════════════
         UI / LAUNCH
         ═══════════════════════════════════════════════════ -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <!-- Support only portrait orientation on iPhone -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- Allow all orientations on iPad -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- ═══════════════════════════════════════════════════
         FLUTTER INTERNAL
         ═══════════════════════════════════════════════════ -->
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>

    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

</dict>
</plist>
